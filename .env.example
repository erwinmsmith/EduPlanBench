# EduPlanBench LLM configuration.
# Copy to .env and fill the key, or export these variables in your shell.
EDUPLAN_LLM_PROVIDER=deepseek
EDUPLAN_LLM_API_KEY=your_deepseek_api_key_here
EDUPLAN_LLM_BASE_URL=https://api.deepseek.com
EDUPLAN_LLM_MODEL=deepseek-chat

# Optional compatibility aliases. EduPlanBench also accepts these, but the
# EDUPLAN_* names above are preferred for one-place LLM configuration.
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_API_KEY=your_openai_compatible_api_key_here

# Experiment defaults.
EDUPLAN_RAW_DIR=rawdataset
EDUPLAN_PROCESSED_DIR=data/processed
EDUPLAN_TASKS_DIR=data/tasks
EDUPLAN_OUTPUTS_DIR=outputs/runs
